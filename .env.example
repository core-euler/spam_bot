# Telegram Bot (from @BotFather)
BOT_TOKEN=123456:ABC-DEF

# Telegram user IDs allowed to use the bot (comma-separated)
ADMIN_ID=123456789

# Telethon (from https://my.telegram.org)
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890
PHONE_NUMBER=+79001234567

# Timezone for admin UI (default: Europe/Moscow)
TIMEZONE=Europe/Moscow

# Database URL (default: sqlite:///data/bot.db)
# DATABASE_URL=sqlite:///data/bot.db

# Max retries for sending messages (default: 3)
# MAX_RETRIES=3
